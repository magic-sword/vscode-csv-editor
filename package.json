{
  "name": "vscode-csv-editor",
  "displayName": "CSV Editor",
  "description": "Large CSV viewer and editor with JSON cell support",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": ["Other"],
  "extensionKind": ["ui", "workspace"],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "csvEditor.openTable",
        "title": "CSVテーブルで開く",
        "icon": "$(table)"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "csvEditor.openTable",
          "when": "resourceExtname == .csv",
          "group": "navigation"
        }
      ],
      "editor/title": [
        {
          "command": "csvEditor.openTable",
          "when": "resourceExtname == .csv",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.90.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.0.0",
    "typescript": "^5.4.0"
  }
}
